{
  "name": "codiva",
  "private": true,
  "version": "1.0.0",
  "description": "Codiva AI website generator",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",

    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend": "cd apps/backend && npm run dev",

    "build": "npm run build:frontend && npm run build:backend",

    "build:frontend": "cd apps/frontend && npm run build",
    "build:backend": "cd apps/backend && npm run build",

    "start": "npm run start:backend",

    "start:frontend": "cd apps/frontend && npm start",
    "start:backend": "cd apps/backend && npm start",

    "worker": "cd apps/backend && node dist/workers/generation.worker.js",

    "prisma:generate": "cd apps/backend && npx prisma generate",
    "prisma:migrate": "cd apps/backend && npx prisma migrate deploy"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}